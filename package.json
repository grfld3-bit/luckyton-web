{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "npx prisma generate && esbuild server.ts --bundle --platform=node --format=cjs --outfile=dist/server.cjs --external:fsevents --external:vite --external:@prisma/client",
    "start": "(npx prisma db push --accept-data-loss || echo 'Prisma migration skipped or failed') && node dist/server.cjs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@prisma/client": "^6.4.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@tailwindcss/vite": "^4.1.14",
    "@telegram-apps/sdk-react": "^3.3.9",
    "@telegram-apps/telegram-ui": "^2.1.13",
    "@ton/core": "^0.63.1",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^16.2.4",
    "@tonconnect/ui-react": "^2.4.4",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.15.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-cron": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-poker": "^0.0.77",
    "scratch-card-react": "^1.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "vite": "^6.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/socket.io": "^3.0.1",
    "@types/socket.io-client": "^1.4.36",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.0",
    "prisma": "^6.4.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
